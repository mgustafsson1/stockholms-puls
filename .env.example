# Trafiklab API key for live GTFS-RT data. If not set, falls back to simulator.
# Register at https://www.trafiklab.se/ to get one.
TRAFIKLAB_KEY=

# OpenRouter API key for AI traffic analyst.
# Register at https://openrouter.ai/ to get one.
# If not set, the AI panel is disabled.
OPENROUTER_KEY=

# How often the AI analyst runs, in milliseconds. Defaults to 90000 (90 s).
AI_INTERVAL_MS=90000

# Backend port. Defaults to 4000. The Vite dev proxy expects this.
PORT=4000
